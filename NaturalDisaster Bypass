-- CHAT BYPASS & GLOBAL SENDER
-- ==========================================
local phoneticWords = {
    ["0"] = "Zer ", ["1"] = "Won ", ["2"] = "Too ", ["3"] = "Tree ", ["4"] = "For ",
    ["5"] = "Fiv ", ["6"] = "Sicks ", ["7"] = "Sevn ", ["8"] = "Ate ", ["9"] = "Nyn "
}

local function translateToPhonetic(str)
    local result = ""
    for i = 1, #str do
        local char = str:sub(i, i)
        if phoneticWords[char] then result = result .. phoneticWords[char] else result = result .. char end
    end
    return result
end

local function sendChatMessage(message)
    task.spawn(function()
        pcall(function()
            if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
                local textChannels = TextChatService:WaitForChild("TextChannels", 5)
                if textChannels then
                    local rbxGeneral = textChannels:WaitForChild("RBXGeneral", 5)
                    if rbxGeneral then rbxGeneral:SendAsync(message) end
                end
            else
                local chatEvents = ReplicatedStorage:WaitForChild("DefaultChatSystemChatEvents", 5)
                if chatEvents then
                    local sayMessageRequest = chatEvents:WaitForChild("SayMessageRequest", 5)
                    if sayMessageRequest then sayMessageRequest:FireServer(message, "All") end
                end
            end
        end)
    end)
end

-- ==========================================
-- PREDICTOR LOGIC
-- ==========================================
local function notifyDisaster(disasterName)
    if table.find(detectedDisasters, disasterName) then return end
    table.insert(detectedDisasters, disasterName)
    
    StatusLabel:Set("Current Disaster(s): " .. table.concat(detectedDisasters, ", "))
    
    if predictEnabled then Rayfield:Notify({ Title = "⚠️ Disaster Predicted!", Content = disasterName .. " has started!", Duration = 8, Image = 4483362458 }) end
    if autoChatEnabled then sendChatMessage("⚠️ Next disaster is: " .. disasterName .. "! ⚠️") end
end

local function hookCharacter(player, character)
    character.ChildAdded:Connect(function(child)
        if child.Name == "SurvivalTag" and child:IsA("StringValue") then
            task.wait(0.1) notifyDisaster(child.Value)
        end
    end)
    
    local hum = character:WaitForChild("Humanoid", 5)
    if hum then
        hum.Died:Connect(function()
            if player == LocalPlayer then
                detectedDisasters = {}
                StatusLabel:Set("Status: Waiting for next round...")
                stopHeadsit()
            end
        end)
    end
end

for _, p in pairs(Players:GetPlayers()) do
    if p.Character then hookCharacter(p, p.Character) end
    p.CharacterAdded:Connect(function(char) hookCharacter(p, char) end)
end
Players.PlayerAdded:Connect(function(p) 
    p.CharacterAdded:Connect(function(char) hookCharacter(p, char) end) 
end)

