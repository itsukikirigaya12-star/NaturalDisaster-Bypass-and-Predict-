-- ==========================================
-- HEADSIT FEATURE (INFINITE YIELD STYLE)
-- ==========================================
local selectedHeadsitPlayer = nil
local headsitConnection = nil

local function stopHeadsit()
    if headsitConnection then 
        headsitConnection:Disconnect() 
        headsitConnection = nil 
    end
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.PlatformStand = false
        for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = true end
        end
    end
end

local function startHeadsit(targetName)
    stopHeadsit()
    local targetPlayer = Players:FindFirstChild(targetName)
    if not targetPlayer then 
        Rayfield:Notify({ Title = "Error", Content = "Player not found!", Duration = 3, Image = 4483362458 })
        return 
    end
    
    Rayfield:Notify({ Title = "Headsit", Content = "Sitting on " .. targetPlayer.Name .. "'s head.", Duration = 3, Image = 4483362458 })
    
    headsitConnection = RunService.Heartbeat:Connect(function()
        local char = LocalPlayer.Character
        local tChar = targetPlayer.Character
        
        if char and tChar and char:FindFirstChild("HumanoidRootPart") and tChar:FindFirstChild("Head") then
            local hrp = char.HumanoidRootPart
            local hum = char:FindFirstChild("Humanoid")
            
            if hum then hum.PlatformStand = true end
            
            for _, v in pairs(char:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
            
            hrp.Velocity = Vector3.new(0, 0, 0)
            hrp.CFrame = tChar.Head.CFrame * CFrame.new(0, 1.5, 0)
        else
            stopHeadsit()
        end
    end)
end

-- ==========================================
-- VEHICLE FLY (MOBILE & PC SUPPORTED)
-- ==========================================
local VFlyEnabled = false
local VFlySpeed = 40 
local VFlyBV = nil
local VFlyBG = nil

local function getSeat()
    local char = LocalPlayer.Character
    if not char then return nil end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or not hum.SeatPart then return nil end
    return hum.SeatPart
end

local function getMoveVector()
    local moveDir = Vector3.new(0, 0, 0)
    pcall(function()
        local playerModule = require(LocalPlayer.PlayerScripts:WaitForChild("PlayerModule", 1))
        if playerModule then
            local controls = playerModule:GetControls()
            if controls then moveDir = controls:GetMoveVector() end
        end
    end)
    if moveDir.Magnitude == 0 then
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + Vector3.new(0, 0, -1) end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir + Vector3.new(0, 0, 1) end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir + Vector3.new(-1, 0, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + Vector3.new(1, 0, 0) end
    end
    return moveDir
end

local function updateVFly()
    if VFlyEnabled then
        local seat = getSeat()
        if not seat then
            if VFlyBV then VFlyBV:Destroy() VFlyBV = nil end
            if VFlyBG then VFlyBG:Destroy() VFlyBG = nil end
            return
        end

        local vehicleRoot = seat.AssemblyRootPart or seat
        if not VFlyBV or VFlyBV.Parent ~= vehicleRoot then
            if VFlyBV then VFlyBV:Destroy() end
            VFlyBV = Instance.new("BodyVelocity")
            VFlyBV.Name = "VFlyBV"
            VFlyBV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            VFlyBV.Parent = vehicleRoot
        end

        if not VFlyBG or VFlyBG.Parent ~= vehicleRoot then
            if VFlyBG then VFlyBG:Destroy() end
            VFlyBG = Instance.new("BodyGyro")
            VFlyBG.Name = "VFlyBG"
            VFlyBG.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            VFlyBG.P = 9000
            VFlyBG.Parent = vehicleRoot
        end

        local camera = workspace.CurrentCamera
        local moveDir = getMoveVector()
        local velocity = Vector3.new(0, 0, 0)

        if moveDir.Magnitude > 0 then
            velocity = velocity + (camera.CFrame.LookVector * -moveDir.Z)
            velocity = velocity + (camera.CFrame.RightVector * moveDir.X)
        end

        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then velocity = velocity + Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then velocity = velocity + Vector3.new(0, -1, 0) end

        VFlyBG.CFrame = camera.CFrame
        if velocity.Magnitude > 0 then
            VFlyBV.Velocity = velocity.Unit * VFlySpeed
        else
            VFlyBV.Velocity = Vector3.new(0, 0, 0)
        end
    else
        if VFlyBV then VFlyBV:Destroy() VFlyBV = nil end
        if VFlyBG then VFlyBG:Destroy() VFlyBG = nil end
    end
end
RunService.RenderStepped:Connect(updateVFly)

